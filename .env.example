# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=ls__sua_api_key_aqui
LANGSMITH_PROJECT=nome-do-seu-projeto
USERNAME_LANGSMITH_HUB=seu-username-no-langsmith-hub

# OpenAI Configuration (opcional — use OpenAI ou Google)
OPENAI_API_KEY=sk-proj-sua_openai_key_aqui

# Google Gemini Configuration (opcional — use OpenAI ou Google)
GOOGLE_API_KEY=AIza_sua_google_key_aqui

# LLM Configuration
# Para OpenAI:
#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini
#EVAL_MODEL=gpt-4o-mini

# Para Google Gemini (free tier — limite: 1500 req/dia):
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
EVAL_MODEL=gemini-2.5-flash
